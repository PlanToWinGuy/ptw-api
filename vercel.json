{
  "functions": {
    "api/goals.js": { "maxDuration": 45 },
    "api/goals/feasibility-check.js": { "maxDuration": 45 },
    "api/goals/clarify.js": { "maxDuration": 45 },
    "api/goals/refine-patch.js": { "maxDuration": 45 },
    "api/metrics.js": { "maxDuration": 45 },
    "api/essential-apps.js": { "maxDuration": 45 },
    "api/ai/chat.js": { "maxDuration": 45 },
    "api/side-quests/custom.js": { "maxDuration": 45 },
    "api/side-quests/[id]/refine.js": { "maxDuration": 45 },
    "api/side-quest-suggestions/index.js": { "maxDuration": 45 }
